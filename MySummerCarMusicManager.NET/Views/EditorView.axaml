<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="using:MySummerCarMusicManager.NET.Helpers"
             xmlns:commonControls="clr-namespace:Classic.CommonControls;assembly=Classic.CommonControls.Avalonia"
             xmlns:vm="using:MySummerCarMusicManager.NET.ViewModels"
             xmlns:classic="using:Avalonia.Classic.Theme"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="MySummerCarMusicManager.NET.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <UserControl.Resources>
        <local:BoolToStatusConverter x:Key="BoolToStatusConverter"/>
    </UserControl.Resources>

   <DockPanel Margin="0,1,0,0">
    
    <ClassicBorderDecorator DockPanel.Dock="Top" BorderThickness="2" BorderStyle="Etched">
        <StackPanel Orientation="Vertical" Margin="0,2"> 
            <DockPanel>
                <commonControls:RebarHandle />
                <Border DockPanel.Dock="Right" Background="Black" Margin="0,-2" >
                    <Image Source="../Icons/Finnish_flag_by_ilyushka88.jpg" Width="19" Height="20" Margin="14,0" />
                </Border>
                <Separator Theme="{StaticResource VerticalSeparator}" Margin="0,-2" DockPanel.Dock="Right" />
                <Menu>
                    <MenuItem Header="File">
                        <MenuItem Header="Add Files" 
                                  Command="{Binding AddFilesCommand}" CommandParameter="{Binding $parent[Window]}"/>
                        <MenuItem Header="Close Folder" 
                                  Command="{Binding CloseFolderCommand}"/>
                        <Separator/>
                        <MenuItem Header="Exit" 
                                  Command="{Binding $parent[Window].Close}"/>
                    </MenuItem>
                    <MenuItem Header= "Edit"> 
                        <MenuItem Header="Select _All" 
                                  Command="{Binding SelectAllCommand}" 
                                  CommandParameter="{Binding #MusicGrid}"/>
                        <Separator/>
                        <MenuItem Header="Remove Track" 
                                  Command="{Binding RemoveTrackCommand}"/>
                    </MenuItem>
                    <MenuItem Header= "View"> 
                        <MenuItem Header="Refresh Library" 
                                  Command="{Binding LoadLibraryCommand}"/>
                    </MenuItem>
                    <MenuItem Header= "Help"> 
                        <MenuItem Header="About" 
                                  Command="{Binding ShowAboutCommand}"
                                  CommandParameter="{Binding $parent[Window]}"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
            <Separator />
            <commonControls:ToolBar TextPlacement="{CompiledBinding ToolbarTextPlacement}" Size="{CompiledBinding ToolbarSize}" GrayscaleIcons="True"> 
                <commonControls:RebarHandle />
                <commonControls:ToolBarButton Text="Add" 
                                              LargeIcon="../Icons/directory_explorer-32.png" 
                                              SmallIcon="../Icons/directory_explorer-16.png" 
                                              Command="{Binding AddFilesCommand}" 
                                              CommandParameter="{Binding $parent[UserControl]}" 
                                              PreferText="True" />
                <commonControls:ToolBarButton Text="Remove" 
                                              LargeIcon="../Icons/recycle_bin_empty_cool-32.png" 
                                              SmallIcon="../Icons/recycle_bin_empty_cool-16.png" 
                                              Command="{Binding RemoveTrackCommand}"
                                              CommandParameter="{Binding #MusicGrid.SelectedItems}"
                                              PreferText="True" />
                <commonControls:ToolBarButton Text="Burn" 
                                              LargeIcon="../Icons/cassette_tape-32.png" 
                                              SmallIcon="../Icons/cassette_tape-16.png" 
                                              Command="{Binding SyncCommand}" 
                                              PreferText="True" />
            </commonControls:ToolBar>
        </StackPanel>
    </ClassicBorderDecorator>

    <ClassicBorderDecorator DockPanel.Dock="Bottom" BorderStyle="Sunken" BorderThickness="2" Margin="2,0,2,2">
        <Grid ColumnDefinitions="*, Auto" Margin="2">
            <TextBlock Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center" 
                       Margin="2,0"/>
            
            <ProgressBar Grid.Column="1" 
                         IsIndeterminate="True" 
                         Width="100" Height="14" 
                         IsVisible="{Binding IsBusy}"/>
        </Grid>
    </ClassicBorderDecorator>

    <ClassicBorderDecorator BorderStyle="Sunken" BorderThickness="2" Margin="2">
        <DataGrid x:Name="MusicGrid"
                  DragDrop.AllowDrop="True"
                  ItemsSource="{Binding Tracks}"
                  SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                  SelectionMode="Extended"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="None" 
                  CanUserResizeColumns="False"
                  CanUserSortColumns="True"
                  BorderThickness="1" BorderBrush="Gray">
            <DataGrid.Columns> 
                <DataGridTextColumn Header="#" Binding="{Binding Position}"/>
                <DataGridTextColumn Header="Artists" Width="2*"  Binding="{Binding ShownAuthors}"/>
                <DataGridTextColumn Header="Title" Width="2*"  Binding="{Binding Title}"/>
                <DataGridTextColumn Header="State" Width="1*"  Binding="{Binding IsReady, Converter={StaticResource BoolToStatusConverter}, Mode=OneWay}"/>
            </DataGrid.Columns>
        </DataGrid>
    </ClassicBorderDecorator>

    <ClassicBorderDecorator DockPanel.Dock="Bottom" BorderStyle="Sunken" BorderThickness="2" Padding="2" Margin="0,2,0,0">
        <Grid ColumnDefinitions="*, Auto">
            <TextBlock Text="{Binding StatusMessage}" Margin="2,0" VerticalAlignment="Center"/>
            <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="100" Height="15" IsVisible="{Binding IsBusy}"/>
        </Grid>
    </ClassicBorderDecorator>

  </DockPanel>
</UserControl>